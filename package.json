{
  "name": "sekiei",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "public:check": "node ./scripts/check-public-ready.mjs && npm run lint && npm run test:unit && npm run build",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "npm run lint:ts && npm run lint:css && npm run lint:html",
    "lint:changed": "powershell -ExecutionPolicy Bypass -File ./scripts/run-lint-on-change.ps1",
    "lint:files": "node ./scripts/run-lint-on-change.mjs --files",
    "lint:ts": "eslint .",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:html": "html-validate .",
    "lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix && prettier . --write",
    "typecheck": "tsc -p tsconfig.json",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@jscad/modeling": "^2.13.0",
    "three": "^0.183.2",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "html-validate": "^10.9.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.2",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
